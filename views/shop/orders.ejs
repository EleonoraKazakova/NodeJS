<%- include('../includes/head.ejs') %>
    </head>
    <body>
<%- include('../includes/navigation.ejs') %>
<main>
    <% if (orders.length <= 0) { %>
        <h1>Nothing there!</h1>
    <% } else { %>
        <ul>
            <% orders.forEach(order => { %>
                <div>
                    <h1># <%= order.id %></h1>
                    <ul>
                        <% order.products.forEach(product => { %>
                            <span><%= product.title %> (<%= product.orderItem.quantity %>)</li>
                        <% }); %>
                    </ul>
                </li>
            <% }); %>
        </ul>
    <% } %>
</main>

<%- include('../includes/end.ejs') %>